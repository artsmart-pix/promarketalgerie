# Server
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database (décommenter pour utiliser PostgreSQL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=promarket_algerie
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=a37e79d273eade7491a847119bb1b9cb0917c95f6e8131b6dabeb2ce09a3052fe9862a4861c6b5d4a9ad26773ac24c95a8f2a36a89fcfd6037e0b0b4f9e46f24
JWT_EXPIRES_IN=7d

# Media Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# AWS S3 (optional — uses local storage if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_BUCKET_NAME=promarket-media

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@promarketalgerie.com
SMTP_PASS=your_smtp_password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Exa API (Search AI) — remplacer par votre clé si vous utilisez la recherche Exa
EXA_API_KEY=
