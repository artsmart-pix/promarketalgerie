{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|next|err" }],
    "no-undef": "error",
    "no-console": "off",
    "semi": ["warn", "always"],
    "no-var": "warn"
  },
  "ignorePatterns": ["node_modules/"]
}
