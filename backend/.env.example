# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=promarket_algerie
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Media Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# AWS S3 (optional — uses local storage if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_BUCKET_NAME=promarket-media

# Email (SMTP)
# Pour Gmail : SMTP_USER = adresse Gmail, SMTP_PASS = "mot de passe d'application"
# (https://myaccount.google.com/apppasswords — nécessite la validation en 2 étapes).
# Tant que SMTP_PASS vaut "your_smtp_password", les emails ne sont PAS envoyés :
# en développement le lien de reset est loggué en console et renvoyé par l'API.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=promarketalgerie@gmail.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Pro Market Algérie <promarketalgerie@gmail.com>

# URL publique de base utilisée dans les liens des emails (sans slash final).
# Laisser vide en local : déduit automatiquement de la requête (ex: http://localhost:3001).
APP_URL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Exa API (Search AI)
EXA_API_KEY=your_exa_api_key_here
