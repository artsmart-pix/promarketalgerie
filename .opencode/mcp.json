{
  "mcpServers": {
    "shadcn": {
      "type": "stdio",
      "command": "bun",
      "args": ["x", "shadcn@latest", "mcp"]
    },
    "nx-mcp": {
      "type": "stdio",
      "command": "bun",
      "args": ["x", "--", "nx-mcp@latest"]
    },
    "playwright": {
      "type": "stdio",
      "command": "bun",
      "args": ["x", "--", "@playwright/mcp@latest"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "bun",
      "args": ["x", "--", "chrome-devtools-mcp@latest"]
    },
    "context7": {
      "type": "stdio",
      "command": "bun",
      "args": ["x", "--", "@upstash/context7-mcp@latest"]
    },
    "gh_grep": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.grep.app"]
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=8b565b64-aeae-40fd-81d1-5850b65c354f"
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\user\\Desktop\\ARTOFDOIND"
      ]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "figma": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "figma-developer-mcp"],
      "env": {
        "FIGMA_API_KEY": "YOUR_FIGMA_API_KEY"
      }
    },
    "sentry": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@sentry/mcp-server"],
      "env": {
        "SENTRY_AUTH_TOKEN": "YOUR_SENTRY_TOKEN"
      }
    },
    "supabase": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "YOUR_SUPABASE_TOKEN"
      }
    },
    "brave-search": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "YOUR_BRAVE_API_KEY"
      }
    }
  }
}
